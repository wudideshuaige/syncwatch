{
  "name": "syncwatch",
  "private": true,
  "version": "0.1.0",
  "description": "SyncWatch - 和朋友一起，实时同步观影",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "build:web": "tsc -b && vite build",
    "build:web:cloud": "tsc -b && cross-env VITE_API_BASE_URL=$CLOUD_URL vite build",
    "build:electron": "tsc -b && vite build && cross-env ELECTRON_BUILDER_CACHE=../.electron-builder-cache electron-builder --win",
    "build:electron:cloud": "tsc -b && cross-env VITE_API_BASE_URL=$CLOUD_URL vite build && cross-env ELECTRON_BUILDER_CACHE=../.electron-builder-cache electron-builder --win",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "server:dev": "nodemon",
    "server:start": "tsx api/server.ts",
    "start": "tsx api/server.ts",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "electron:dev": "concurrently -k \"npm run client:dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:start": "electron .",
    "cap:sync": "npm run build:web && npx cap sync",
    "cap:sync:cloud": "npm run build:web:cloud && npx cap sync",
    "cap:android": "npx cap open android",
    "cap:run:android": "npm run build:web && npx cap sync android && npx cap run android",
    "start:all": "powershell -ExecutionPolicy Bypass -File start.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/status-bar": "^8.0.2",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.511.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.0.2",
    "tsx": "^4.20.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vercel/node": "^5.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.0",
    "vite": "^6.3.5",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.syncwatch.app",
    "productName": "SyncWatch",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
